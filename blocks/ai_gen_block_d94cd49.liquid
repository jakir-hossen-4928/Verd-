
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .vd-story-{{ ai_gen_id }} {
    display: block;
    background: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
  }

  .vd-story-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.gap_mobile }}px;
    align-items: center;
  }

  .vd-story-img-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background: {{ block.settings.image_placeholder_bg }};
    box-shadow: 0 {{ block.settings.image_shadow_y }}px {{ block.settings.image_shadow_blur }}px {{ block.settings.image_shadow_spread }}px {{ block.settings.image_shadow_color }};
  }

  .vd-story-img-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .vd-story-img-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.image_placeholder_bg }};
  }

  .vd-story-img-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .vd-story-badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_position_top }}px;
    left: {{ block.settings.badge_position_left }}px;
    background: {{ block.settings.badge_bg_color }};
    backdrop-filter: blur({{ block.settings.badge_blur }}px);
    border-radius: {{ block.settings.badge_border_radius }}px;
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    letter-spacing: {{ block.settings.badge_letter_spacing }};
    text-transform: {{ block.settings.badge_text_transform }};
    color: {{ block.settings.badge_text_color }};
  }

  .vd-story-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_font_size }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }};
    text-transform: {{ block.settings.eyebrow_text_transform }};
    color: {{ block.settings.eyebrow_color }};
  }

  .vd-story-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font_weight }};
    font-size: {{ block.settings.title_font_size_mobile }}px;
    line-height: {{ block.settings.title_line_height }};
    letter-spacing: {{ block.settings.title_letter_spacing }};
    margin: {{ block.settings.title_margin_top }}px 0 {{ block.settings.title_margin_bottom }}px;
  }

  .vd-story-title-{{ ai_gen_id }} em {
    font-style: {{ block.settings.title_em_style }};
    color: {{ block.settings.title_em_color }};
    font-weight: {{ block.settings.title_em_font_weight }};
  }

  .vd-story-p-{{ ai_gen_id }} {
    color: {{ block.settings.paragraph_color }};
    line-height: {{ block.settings.paragraph_line_height }};
    margin: 0 0 {{ block.settings.paragraph_margin_bottom }}px;
    max-width: {{ block.settings.paragraph_max_width }}px;
    font-size: {{ block.settings.paragraph_font_size }}px;
  }

  .vd-story-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: {{ block.settings.list_margin_top }}px 0 0;
    display: grid;
    gap: {{ block.settings.list_item_gap }}px;
  }

  .vd-story-list-{{ ai_gen_id }} li {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.list_icon_gap }}px;
    font-size: {{ block.settings.list_font_size }}px;
    color: {{ block.settings.list_text_color }};
  }

  .vd-story-list-{{ ai_gen_id }} svg {
    flex-shrink: 0;
    margin-top: {{ block.settings.list_icon_margin_top }}px;
    color: {{ block.settings.list_icon_color }};
    width: {{ block.settings.list_icon_size }}px;
    height: {{ block.settings.list_icon_size }}px;
  }

  .vd-story-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.cta_icon_gap }}px;
    margin-top: {{ block.settings.cta_margin_top }}px;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    border-radius: {{ block.settings.cta_border_radius }}px;
    background: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    font-size: {{ block.settings.cta_font_size }}px;
    letter-spacing: {{ block.settings.cta_letter_spacing }};
    text-transform: {{ block.settings.cta_text_transform }};
    text-decoration: none;
    transition: background 0.3s ease, color 0.3s ease;
    border: {{ block.settings.cta_border_width }}px {{ block.settings.cta_border_style }} {{ block.settings.cta_border_color }};
  }

  .vd-story-cta-{{ ai_gen_id }}:hover {
    background: {{ block.settings.cta_bg_hover_color }};
    color: {{ block.settings.cta_text_hover_color }};
  }

  @media (min-width: 900px) {
    .vd-story-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_desktop }}px {{ block.settings.padding_horizontal_desktop }}px {{ block.settings.padding_bottom_desktop }}px;
    }

    .vd-story-inner-{{ ai_gen_id }} {
      grid-template-columns: {% if block.settings.layout_desktop == 'image_left' %}1fr 1fr{% else %}1fr 1fr{% endif %};
      gap: {{ block.settings.gap_desktop }}px;
    }

    {% if block.settings.layout_desktop == 'image_right' %}
      .vd-story-img-{{ ai_gen_id }} {
        order: 2;
      }
    {% endif %}

    .vd-story-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_desktop }}px;
    }
  }
{% endstyle %}

<section class="vd-story-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="vd-story-inner-{{ ai_gen_id }}">
    <div class="vd-story-img-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="vd-story-img-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
      {% if block.settings.badge_text != blank %}
        <div class="vd-story-badge-{{ ai_gen_id }}">{{ block.settings.badge_text }}</div>
      {% endif %}
    </div>
    <div>
      {% if block.settings.eyebrow_text != blank %}
        <div class="vd-story-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</div>
      {% endif %}
      {% if block.settings.title != blank %}
        <h2 class="vd-story-title-{{ ai_gen_id }}">
          {{ block.settings.title }}
        </h2>
      {% endif %}
      {% if block.settings.paragraph_1 != blank %}
        <div class="vd-story-p-{{ ai_gen_id }}">
          {{ block.settings.paragraph_1 }}
        </div>
      {% endif %}
      {% if block.settings.paragraph_2 != blank %}
        <div class="vd-story-p-{{ ai_gen_id }}">
          {{ block.settings.paragraph_2 }}
        </div>
      {% endif %}
      {% if block.settings.show_list %}
        <ul class="vd-story-list-{{ ai_gen_id }}">
          {% if block.settings.list_item_1 != blank %}
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 6 9 17l-5-5"/>
              </svg>
              {{ block.settings.list_item_1 }}
            </li>
          {% endif %}
          {% if block.settings.list_item_2 != blank %}
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 6 9 17l-5-5"/>
              </svg>
              {{ block.settings.list_item_2 }}
            </li>
          {% endif %}
          {% if block.settings.list_item_3 != blank %}
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 6 9 17l-5-5"/>
              </svg>
              {{ block.settings.list_item_3 }}
            </li>
          {% endif %}
        </ul>
      {% endif %}
      {% if block.settings.cta_text != blank and block.settings.cta_link != blank %}
        <a href="{{ block.settings.cta_link }}" class="vd-story-cta-{{ ai_gen_id }}">
          {{ block.settings.cta_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_desktop",
      "label": "Desktop layout",
      "options": [
        {
          "value": "image_left",
          "label": "Image left"
        },
        {
          "value": "image_right",
          "label": "Image right"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Gap between columns (desktop)",
      "min": 20,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap between columns (mobile)",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Top padding (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Bottom padding (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_horizontal_desktop",
      "label": "Horizontal padding (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Horizontal padding (mobile)",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#F9F8F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2D3A31"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_aspect_ratio",
      "label": "Aspect ratio",
      "default": "4/5"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "image_placeholder_bg",
