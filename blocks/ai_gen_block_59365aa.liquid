
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bestsellers-{{ ai_gen_id }} {
    display: block;
    background: {{ block.settings.section_bg_color }};
    color: {{ block.settings.section_text_color }};
    padding: {{ block.settings.section_padding_top_desktop }}px {{ block.settings.section_padding_horizontal_desktop }}px {{ block.settings.section_padding_bottom_desktop }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-bestsellers-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-bestsellers-head-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_text_align }};
    margin-bottom: {{ block.settings.header_margin_bottom_desktop }}px;
  }

  .ai-bestsellers-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_font_size_desktop }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }};
    text-transform: {{ block.settings.eyebrow_text_transform }};
    color: {{ block.settings.eyebrow_color }};
    font-weight: {{ block.settings.eyebrow_font_weight }};
    line-height: {{ block.settings.eyebrow_line_height }};
    margin-bottom: {{ block.settings.eyebrow_margin_bottom }}px;
  }

  .ai-bestsellers-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size_desktop }}px;
    line-height: {{ block.settings.title_line_height }};
    letter-spacing: {{ block.settings.title_letter_spacing }};
    margin: 0;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    text-transform: {{ block.settings.title_text_transform }};
  }

  .ai-bestsellers-title-{{ ai_gen_id }} em {
    font-style: {{ block.settings.title_em_font_style }};
    color: {{ block.settings.title_em_color }};
    font-weight: {{ block.settings.title_em_font_weight }};
  }

  .ai-bestsellers-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.grid_gap_mobile }}px;
  }

  .ai-prod-{{ ai_gen_id }} {
    background: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding_top }}px {{ block.settings.card_padding_horizontal }}px {{ block.settings.card_padding_bottom }}px;
    transition: transform {{ block.settings.card_hover_transition_duration }}s ease, box-shadow {{ block.settings.card_hover_transition_duration }}s ease;
    border: {{ block.settings.card_border_width }}px {{ block.settings.card_border_style }} {{ block.settings.card_border_color }};
  }

  .ai-prod-{{ ai_gen_id }}:hover {
    transform: translateY({{ block.settings.card_hover_translate_y }}px);
    box-shadow: {{ block.settings.card_hover_shadow_x }}px {{ block.settings.card_hover_shadow_y }}px {{ block.settings.card_hover_shadow_blur }}px {{ block.settings.card_hover_shadow_spread }}px {{ block.settings.card_hover_shadow_color }};
  }

  .ai-prod-img-wrapper-{{ ai_gen_id }} {
    cursor: pointer;
  }

  .ai-prod-img-{{ ai_gen_id }} {
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background: {{ block.settings.image_placeholder_bg }};
    margin-bottom: {{ block.settings.image_margin_bottom }}px;
    position: relative;
  }

  .ai-prod-img-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_object_fit }};
    display: block;
    transition: transform {{ block.settings.image_hover_transition_duration }}s ease;
  }

  .ai-prod-{{ ai_gen_id }}:hover .ai-prod-img-{{ ai_gen_id }} img {
    transform: scale({{ block.settings.image_hover_scale }});
  }

  .ai-prod-img-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-prod-tag-{{ ai_gen_id }} {
    font-size: {{ block.settings.tag_font_size_desktop }}px;
    letter-spacing: {{ block.settings.tag_letter_spacing }};
    text-transform: {{ block.settings.tag_text_transform }};
    color: {{ block.settings.tag_color }};
    font-weight: {{ block.settings.tag_font_weight }};
    line-height: {{ block.settings.tag_line_height }};
    margin-bottom: {{ block.settings.tag_margin_bottom }}px;
  }

  .ai-prod-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_name_font_size_desktop }}px;
    font-weight: {{ block.settings.product_name_font_weight }};
    margin: {{ block.settings.product_name_margin_top }}px 0 {{ block.settings.product_name_margin_bottom }}px;
    line-height: {{ block.settings.product_name_line_height }};
    color: {{ block.settings.product_name_color }};
    text-transform: {{ block.settings.product_name_text_transform }};
    letter-spacing: {{ block.settings.product_name_letter_spacing }};
    cursor: pointer;
  }

  .ai-prod-desc-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size_desktop }}px;
    color: {{ block.settings.description_color }};
    line-height: {{ block.settings.description_line_height }};
    margin: 0 0 {{ block.settings.description_margin_bottom }}px;
    font-weight: {{ block.settings.description_font_weight }};
    letter-spacing: {{ block.settings.description_letter_spacing }};
  }

  .ai-prod-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: {{ block.settings.footer_gap }}px;
    padding-top: {{ block.settings.footer_padding_top }}px;
    border-top: {{ block.settings.footer_border_width }}px {{ block.settings.footer_border_style }} {{ block.settings.footer_border_color }};
  }

  .ai-prod-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size_desktop }}px;
    font-weight: {{ block.settings.price_font_weight }};
    color: {{ block.settings.price_color }};
    line-height: {{ block.settings.price_line_height }};
    letter-spacing: {{ block.settings.price_letter_spacing }};
  }

  .ai-prod-btn-{{ ai_gen_id }} {
    background: {{ block.settings.button_bg_color }};
    border: {{ block.settings.button_border_width }}px {{ block.settings.button_border_style }} {{ block.settings.button_border_color }};
    color: {{ block.settings.button_text_color }};
    padding: {{ block.settings.button_padding_top }}px {{ block.settings.button_padding_horizontal }}px {{ block.settings.button_padding_bottom }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size_desktop }}px;
    letter-spacing: {{ block.settings.button_letter_spacing }};
    text-transform: {{ block.settings.button_text_transform }};
    cursor: pointer;
    transition: all {{ block.settings.button_transition_duration }}s ease;
    font-weight: {{ block.settings.button_font_weight }};
    line-height: {{ block.settings.button_line_height }};
  }

  .ai-prod-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-prod-btn-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

