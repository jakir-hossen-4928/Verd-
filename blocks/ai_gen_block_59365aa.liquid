<bestsellers-section-{{ ai_gen_id }} class="ai-bestsellers-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bestsellers-inner-{{ ai_gen_id }}">
    <header class="ai-bestsellers-head-{{ ai_gen_id }}">
      {% if block.settings.eyebrow_text != blank %}
        <div class="ai-bestsellers-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</div>
      {% endif %}
      {% if block.settings.title_text != blank %}
        <h2 class="ai-bestsellers-title-{{ ai_gen_id }}">
          {{ block.settings.title_text }}
        </h2>
      {% endif %}
    </header>
    <div class="ai-bestsellers-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign product_key = 'product_' | append: i
          assign tag_key = 'product_' | append: i | append: '_tag'
          assign desc_key = 'product_' | append: i | append: '_description'
          assign product = block.settings[product_key]
          assign tag = block.settings[tag_key]
          assign desc = block.settings[desc_key]
        %}
        <article class="ai-prod-{{ ai_gen_id }}" data-product-index="{{ i }}">
          <div class="ai-prod-img-wrapper-{{ ai_gen_id }}" data-product-url="{% if product %}{{ product.url }}{% endif %}">
            <div class="ai-prod-img-{{ ai_gen_id }}">
              {% if product and product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="800"
                  height="960"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag }}
              {% endif %}
            </div>
          </div>
          {% if tag != blank %}
            <div class="ai-prod-tag-{{ ai_gen_id }}">{{ tag }}</div>
          {% endif %}
          {% if product %}
            <h3 class="ai-prod-name-{{ ai_gen_id }}" data-product-url="{{ product.url }}">{{ product.title }}</h3>
          {% else %}
            <h3 class="ai-prod-name-{{ ai_gen_id }}">Product name</h3>
          {% endif %}
          {% if desc != blank %}
            <p class="ai-prod-desc-{{ ai_gen_id }}">{{ desc }}</p>
          {% endif %}
          <div class="ai-prod-row-{{ ai_gen_id }}">
            {% if product %}
              <div class="ai-prod-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
            {% else %}
              <div class="ai-prod-price-{{ ai_gen_id }}\">$0.00</div>
            {% endif %}
            {% if product %}
              <button 
                class="ai-prod-btn-{{ ai_gen_id }}" 
                type="button"
                data-product-id="{{ product.id }}"
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
              >
                {{ block.settings.button_text }}
              </button>
            {% else %}
              <button class="ai-prod-btn-{{ ai_gen_id }}" type="button" disabled>
                {{ block.settings.button_text }}
              </button>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</bestsellers-section-{{ ai_gen_id }}>

<script>
  (function() {
    class BestsellersSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-prod-btn-{{ ai_gen_id }}');
        this.productImages = this.querySelectorAll('.ai-prod-img-wrapper-{{ ai_gen_id }}');
        this.productNames = this.querySelectorAll('.ai-prod-name-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            this.handleAddToCart(button);
          });
        });

        this.productImages.forEach((imageWrapper) => {
          const productUrl = imageWrapper.getAttribute('data-product-url');
          if (productUrl) {
            imageWrapper.addEventListener('click', () => {
              window.location.href = productUrl;
            });
          }
        });

        this.productNames.forEach((nameElement) => {
          const productUrl = nameElement.getAttribute('data-product-url');
          if (productUrl) {
            nameElement.addEventListener('click', () => {
              window.location.href = productUrl;
            });
          }
        });
      }

      async handleAddToCart(button) {
        const variantId = button.getAttribute('data-variant-id');
        
        if (!variantId) {
          console.error('No variant ID found');
          return;
        }

        const originalText = button.textContent;
        button.disabled = true;
        button.textContent = 'Adding...';

        try {
          const addResponse = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              items: [{
                id: variantId,
                quantity: 1
              }]
            })
          });

          if (!addResponse.ok) {
            throw new Error('Failed to add to cart');
          }

          const addedItem = await addResponse.json();

          button.textContent = 'Added!';
          
          setTimeout(() => {
            button.disabled = false;
            button.textContent = originalText;
          }, 1500);

          await this.fetchCartData();

        } catch (error) {
          console.error('Error adding to cart:', error);
          button.disabled = false;
          button.textContent = originalText;
          alert('Error adding product to cart. Please try again.');
        }
      }

      async fetchCartData() {
        try {
          const cartResponse = await fetch('/cart.js');
          const cartData = await cartResponse.json();
          
          document.dispatchEvent(new CustomEvent('cart:updated', { 
            detail: cartData 
          }));

          this.updateCartCount(cartData.item_count);

          // Integrate with Halo theme sidebar cart
          if (window.sharedFunctions && typeof window.sharedFunctions.updateSidebarCart === 'function') {
            window.sharedFunctions.updateSidebarCart(cartData);
          }

          this.openCartDrawer();

          return cartData;
        } catch (error) {
          console.error('Error fetching cart data:', error);
          return null;
        }
      }

      updateCartCount(count) {
        const cartCountElements = document.querySelectorAll('[data-cart-count], .cart-count, #cart-count');
        cartCountElements.forEach(element => {
          element.textContent = count;
          if (count > 0) {
            element.style.display = '';
          }
        });
      }

      openCartDrawer() {
        const $body = document.body;
        
        // Open Halo sidebar cart by adding the class
        $body.classList.add('cart-sidebar-show');

        // Fallback for other potential drawer types if necessary
        const cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer && typeof cartDrawer.open === 'function') {
          cartDrawer.open();
        }
      }
    }

    customElements.define('bestsellers-section-{{ ai_gen_id }}', BestsellersSection{{ ai_gen_id }});
  })();
</script>

