
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .vd-tst-{{ ai_gen_id }} {
    display: block;
    background: {{ block.settings.section_bg_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_left_right_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    width: 100%;
  }

  .vd-tst-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .vd-tst-head-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.header_gap_mobile }}px;
    margin-bottom: {{ block.settings.header_margin_bottom_mobile }}px;
    align-items: end;
  }

  .vd-tst-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_font_size_mobile }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }};
    text-transform: {{ block.settings.eyebrow_text_transform }};
    color: {{ block.settings.eyebrow_color }};
    font-weight: {{ block.settings.eyebrow_font_weight }};
  }

  .vd-tst-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size_mobile }}px;
    line-height: {{ block.settings.title_line_height }};
    letter-spacing: {{ block.settings.title_letter_spacing }};
    margin: {{ block.settings.title_margin_top }}px 0 0;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
  }

  .vd-tst-title-{{ ai_gen_id }} em {
    font-style: {{ block.settings.title_em_font_style }};
    color: {{ block.settings.title_em_color }};
    font-weight: {{ block.settings.title_em_font_weight }};
  }

  .vd-tst-meta-{{ ai_gen_id }} {
    color: {{ block.settings.meta_color }};
    font-size: {{ block.settings.meta_font_size_mobile }}px;
    line-height: {{ block.settings.meta_line_height }};
    margin: 0;
    max-width: {{ block.settings.meta_max_width }}px;
  }

  .vd-tst-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.grid_gap_mobile }}px;
  }

  .vd-tst-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding_mobile }}px;
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_spread }}px {{ block.settings.card_shadow_color }};
    transition: transform {{ block.settings.card_hover_duration }}s ease;
    border: {{ block.settings.card_border_width }}px {{ block.settings.card_border_style }} {{ block.settings.card_border_color }};
  }

  .vd-tst-card-{{ ai_gen_id }}:hover {
    transform: translateY({{ block.settings.card_hover_translate }}px);
  }

  .vd-tst-stars-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.stars_gap }}px;
    margin-bottom: {{ block.settings.stars_margin_bottom }}px;
    color: {{ block.settings.stars_color }};
  }

  .vd-tst-stars-{{ ai_gen_id }} svg {
    width: {{ block.settings.stars_size_mobile }}px;
    height: {{ block.settings.stars_size_mobile }}px;
  }

  .vd-tst-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_font_size_mobile }}px;
    line-height: {{ block.settings.quote_line_height }};
    margin: 0 0 {{ block.settings.quote_margin_bottom }}px;
    color: {{ block.settings.quote_color }};
    font-style: {{ block.settings.quote_font_style }};
    font-weight: {{ block.settings.quote_font_weight }};
  }

  .vd-tst-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.author_gap }}px;
    padding-top: {{ block.settings.author_padding_top }}px;
    border-top: {{ block.settings.author_border_width }}px {{ block.settings.author_border_style }} {{ block.settings.author_border_color }};
  }

  .vd-tst-avatar-{{ ai_gen_id }} {
    width: {{ block.settings.avatar_size_mobile }}px;
    height: {{ block.settings.avatar_size_mobile }}px;
    border-radius: {{ block.settings.avatar_border_radius }}%;
    background: {{ block.settings.avatar_bg_color }};
    display: grid;
    place-items: center;
    color: {{ block.settings.avatar_text_color }};
    font-weight: {{ block.settings.avatar_font_weight }};
    font-size: {{ block.settings.avatar_font_size_mobile }}px;
    flex-shrink: 0;
  }

  .vd-tst-name-{{ ai_gen_id }} {
    font-weight: {{ block.settings.name_font_weight }};
    font-size: {{ block.settings.name_font_size_mobile }}px;
    color: {{ block.settings.name_color }};
  }

  .vd-tst-role-{{ ai_gen_id }} {
    font-size: {{ block.settings.role_font_size_mobile }}px;
    color: {{ block.settings.role_color }};
    letter-spacing: {{ block.settings.role_letter_spacing }};
  }

  @media (min-width: 700px) {
    .vd-tst-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap_tablet }}px;
    }

    .vd-tst-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_tablet }}px {{ block.settings.section_padding_left_right_tablet }}px {{ block.settings.section_padding_bottom_tablet }}px;
    }

    .vd-tst-head-{{ ai_gen_id }} {
      gap: {{ block.settings.header_gap_tablet }}px;
      margin-bottom: {{ block.settings.header_margin_bottom_tablet }}px;
    }

    .vd-tst-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size_tablet }}px;
    }

    .vd-tst-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_tablet }}px;
    }

    .vd-tst-meta-{{ ai_gen_id }} {
      font-size: {{ block.settings.meta_font_size_tablet }}px;
    }

    .vd-tst-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_tablet }}px;
    }

    .vd-tst-stars-{{ ai_gen_id }} svg {
      width: {{ block.settings.stars_size_tablet }}px;
      height: {{ block.settings.stars_size_tablet }}px;
    }

    .vd-tst-quote-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_font_size_tablet }}px;
    }

    .vd-tst-avatar-{{ ai_gen_id }} {
      width: {{ block.settings.avatar_size_tablet }}px;
      height: {{ block.settings.avatar_size_tablet }}px;
      font-size: {{ block.settings.avatar_font_size_tablet }}px;
    }

    .vd-tst-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.name_font_size_tablet }}px;
    }

    .vd-tst-role-{{ ai_gen_id }} {
      font-size: {{ block.settings.role_font_size_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    .vd-tst-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_left_right }}px {{ block.settings.section_padding_bottom }}px;
    }

    .vd-tst-head-{{ ai_gen_id }} {
      grid-template-columns: {{ block.settings.header_col_left }}fr {{ block.settings.header_col_right }}fr;
      gap: {{ block.settings.header_gap }}px;
      margin-bottom: {{ block.settings.header_margin_bottom }}px;
    }

    .vd-tst-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.grid_gap }}px;
    }

    {% if block.settings.enable_stagger %}
      .vd-tst-grid-{{ ai_gen_id }} > :nth-child({{ block.settings.stagger_nth_child }}) {
        transform: translateY({{ block.settings.stagger_offset }}px);
      }
    {% endif %}

    .vd-tst-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size }}px;
    }

    .vd-tst-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size }}px;
    }

    .vd-tst-meta-{{ ai_gen_id }} {
      font-size: {{ block.settings.meta_font_size }}px;
    }

    .vd-tst-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding }}px;
    }

    .vd-tst-stars-{{ ai_gen_id }} svg {
      width: {{ block.settings.stars_size }}px;
      height: {{ block.settings.stars_size }}px;
    }

    .vd-tst-quote-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_font_size }}px;
    }

    .vd-tst-avatar-{{ ai_gen_id }} {
      width: {{ block.settings.avatar_size }}px;
      height: {{ block.settings.avatar_size }}px;
      font-size: {{ block.settings.avatar_font_size }}px;
    }

    .vd-tst-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.name_font_size }}px;
    }

    .vd-tst-role-{{ ai_gen_id }} {
      font-size: {{ block.settings.role_font_size }}px;
    }
  }
{% endstyle %}

<testimonials-{{ ai_gen_id }} class="vd-tst-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="vd-tst-inner-{{ ai_gen_id }}">
    <header class="vd-tst-head-{{ ai_gen_id }}">
      <div>
        {% if block.settings.eyebrow_text != blank %}
          <div class="vd-tst-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</div>
        {% endif %}
        {% if block.settings.title_text != blank %}
          <h2 class="vd-tst-title-{{ ai_gen_id }}">{{ block.settings.title_text }}</h2>
        {% endif %}
      </div>
      {% if block.settings.meta_text != blank %}
        <p class="vd-tst-meta-{{ ai_gen_id }}">{{ block.settings.meta_text }}</p>
      {% endif %}
    </header>
    <div class="vd-tst-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign quote_key = 'testimonial_' | append: i | append: '_quote'
          assign name_key = 'testimonial_' | append: i | append: '_name'
          assign role_key = 'testimonial_' | append: i | append: '_role'
          assign initial_key = 'testimonial_' | append: i | append: '_initial'

          assign quote = block.settings[quote_key]
          assign name = block.settings[name_key]
          assign role = block.settings[role_key]
          assign initial = block.settings[initial_key]
        %}

        <article class="vd-tst-card-{{ ai_gen_id }}">
          <div class="vd-tst-stars-{{ ai_gen_id }}">
            {% for j in (1..5) %}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="m12 2 3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/>
              </svg>
            {% endfor %}
          </div>
          {% if quote != blank %}
            <p class="vd-tst-quote-{{ ai_gen_id }}">"{{ quote }}"</p>
          {% endif %}
          <div class="vd-tst-author-{{ ai_gen_id }}">
            {% if initial != blank %}
              <div class="vd-tst-avatar-{{ ai_gen_id }}">{{ initial }}</div>
            {% endif %}
            <div>
              {% if name != blank %}
                <div class="vd-tst-name-{{ ai_gen_id }}">{{ name }}</div>
              {% endif %}
              {% if role != blank %}
                <div class="vd-tst-role-{{ ai_gen_id }}">{{ role }}</div>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</testimonials-{{ ai_gen_id }}>

<script>
  (function() {
    class Testimonials{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('testimonials-{{ ai_gen_id }}', Testimonials{{ ai_gen_id }});
  })();
</script>

