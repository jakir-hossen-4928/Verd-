
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .vd-hero-{{ ai_gen_id }} {
    display: block;
    background: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  }

  .vd-hero-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px;
  }

  .vd-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.mobile_gap }}px;
    align-items: center;
  }

  {% if block.settings.mobile_image_position == 'top' %}
    .vd-content-{{ ai_gen_id }} {
      order: 2;
    }
    .vd-img-wrap-{{ ai_gen_id }} {
      order: 1;
    }
  {% else %}
    .vd-content-{{ ai_gen_id }} {
      order: 1;
    }
    .vd-img-wrap-{{ ai_gen_id }} {
      order: 2;
    }
  {% endif %}

  .vd-eyebrow-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: {{ block.settings.mobile_eyebrow_font_size }}px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: {{ block.settings.mobile_eyebrow_margin_bottom }}px;
  }

  .vd-eyebrow-{{ ai_gen_id }}::before {
    content: "";
    width: 36px;
    height: 1px;
    background: {{ block.settings.eyebrow_color }};
    display: inline-block;
  }

  .vd-headline-{{ ai_gen_id }} {
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 600;
    font-size: {{ block.settings.mobile_headline_font_size }}px;
    line-height: {{ block.settings.mobile_headline_line_height }};
    letter-spacing: -0.02em;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.mobile_headline_margin_bottom }}px;
  }

  .vd-headline-{{ ai_gen_id }} em {
    font-style: italic;
    color: {{ block.settings.headline_accent_color }};
    font-weight: 500;
  }

  .vd-sub-{{ ai_gen_id }} {
    font-size: {{ block.settings.mobile_subtext_font_size }}px;
    line-height: {{ block.settings.mobile_subtext_line_height }};
    color: {{ block.settings.subtext_color }};
    max-width: 100%;
    margin: 0 0 {{ block.settings.mobile_subtext_margin_bottom }}px;
  }

  .vd-cta-row-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.mobile_button_gap }}px;
    flex-wrap: wrap;
    align-items: center;
    {% if block.settings.mobile_buttons_stack %}
      flex-direction: column;
      align-items: stretch;
    {% endif %}
  }

  .vd-btn-primary-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: {{ block.settings.mobile_button_padding_vertical }}px {{ block.settings.mobile_button_padding_horizontal }}px;
    border-radius: {{ block.settings.primary_button_radius }}px;
    background: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_color }};
    font-size: {{ block.settings.mobile_button_font_size }}px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    {% if block.settings.mobile_buttons_stack %}
      width: 100%;
    {% endif %}
  }

  .vd-btn-primary-{{ ai_gen_id }}:hover {
    background: {{ block.settings.primary_button_hover_bg }};
    transform: translateY(-1px);
  }

  .vd-btn-ghost-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: {{ block.settings.mobile_button_padding_vertical }}px {{ block.settings.mobile_button_padding_horizontal }}px;
    border-radius: {{ block.settings.secondary_button_radius }}px;
    background: transparent;
    color: {{ block.settings.secondary_button_color }};
    font-size: {{ block.settings.mobile_button_font_size }}px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid {{ block.settings.secondary_button_border }};
    cursor: pointer;
    transition: all 0.3s ease;
    {% if block.settings.mobile_buttons_stack %}
      width: 100%;
    {% endif %}
  }

  .vd-btn-ghost-{{ ai_gen_id }}:hover {
    background: {{ block.settings.secondary_button_hover_bg }};
    color: {{ block.settings.secondary_button_hover_color }};
  }

  .vd-img-wrap-{{ ai_gen_id }} {
    position: relative;
  }

  .vd-arch-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.mobile_image_aspect_ratio }};
    border-top-left-radius: {{ block.settings.mobile_image_border_radius }}px;
    border-top-right-radius: {{ block.settings.mobile_image_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(45, 58, 49, 0.18);
    background: {{ block.settings.image_placeholder_bg }};
  }

  .vd-arch-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .vd-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.image_placeholder_bg }};
  }

  .vd-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .vd-quote-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.mobile_quote_bottom }}px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - {{ block.settings.mobile_quote_horizontal_spacing }}px);
    max-width: 360px;
    background: {{ block.settings.quote_bg }};
    backdrop-filter: blur(10px);
    border-radius: {{ block.settings.quote_border_radius }}px;
    padding: {{ block.settings.mobile_quote_padding }}px;
    box-shadow: 0 10px 30px -10px rgba(45, 58, 49, 0.15);
  }

  .vd-quote-{{ ai_gen_id }} p {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: {{ block.settings.mobile_quote_font_size }}px;
    line-height: 1.4;
    margin: 0;
    color: {{ block.settings.quote_text_color }};
  }

  .vd-stats-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.mobile_stats_gap }}px;
    margin-top: {{ block.settings.mobile_stats_margin_top }}px;
    padding-top: {{ block.settings.mobile_stats_padding_top }}px;
    border-top: 1px solid {{ block.settings.stats_border_color }};
    flex-wrap: wrap;
  }

  .vd-stat-num-{{ ai_gen_id }} {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: {{ block.settings.mobile_stat_number_size }}px;
    font-weight: 600;
    color: {{ block.settings.stat_number_color }};
    line-height: 1;
  }

  .vd-stat-lbl-{{ ai_gen_id }} {
    font-size: {{ block.settings.mobile_stat_label_size }}px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ block.settings.stat_label_color }};
    margin-top: 8px;
  }

  @media (min-width: 768px) {
    .vd-hero-inner-{{ ai_gen_id }} {
      padding: {{ block.settings.desktop_padding_top }}px {{ block.settings.desktop_padding_horizontal }}px {{ block.settings.desktop_padding_bottom }}px;
    }

    .vd-grid-{{ ai_gen_id }} {
      grid-template-columns: 1.05fr 1fr;
      gap: {{ block.settings.desktop_gap }}px;
    }

    .vd-content-{{ ai_gen_id }} {
      order: 1;
    }

    .vd-img-wrap-{{ ai_gen_id }} {
      order: 2;
    }

    .vd-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.desktop_eyebrow_font_size }}px;
      margin-bottom: {{ block.settings.desktop_eyebrow_margin_bottom }}px;
    }

    .vd-headline-{{ ai_gen_id }} {
      font-size: clamp(2.8rem, 7vw, {{ block.settings.desktop_headline_font_size }}px);
      line-height: {{ block.settings.desktop_headline_line_height }};
      margin-bottom: {{ block.settings.desktop_headline_margin_bottom }}px;
    }

    .vd-sub-{{ ai_gen_id }} {
      font-size: {{ block.settings.desktop_subtext_font_size }}px;
      line-height: {{ block.settings.desktop_subtext_line_height }};
      max-width: 480px;
      margin-bottom: {{ block.settings.desktop_subtext_margin_bottom }}px;
    }

    .vd-cta-row-{{ ai_gen_id }} {
      gap: {{ block.settings.desktop_button_gap }}px;
      flex-direction: row;
      align-items: center;
    }

    .vd-btn-primary-{{ ai_gen_id }},
    .vd-btn-ghost-{{ ai_gen_id }} {
      padding: {{ block.settings.desktop_button_padding_vertical }}px {{ block.settings.desktop_button_padding_horizontal }}px;
      font-size: {{ block.settings.desktop_button_font_size }}px;
      width: auto;
    }

    .vd-arch-{{ ai_gen_id }} {
      aspect-ratio: {{ block.settings.desktop_image_aspect_ratio }};
      border-top-left-radius: {{ block.settings.desktop_image_border_radius }}px;
      border-top-right-radius: {{ block.settings.desktop_image_border_radius }}px;
    }

    .vd-quote-{{ ai_gen_id }} {
      bottom: {{ block.settings.desktop_quote_bottom }}px;
      width: calc(100% - {{ block.settings.desktop_quote_horizontal_spacing }}px);
      padding: {{ block.settings.desktop_quote_padding }}px;
    }

    .vd-quote-{{ ai_gen_id }} p {
      font-size: {{ block.settings.desktop_quote_font_size }}px;
    }

    .vd-stats-{{ ai_gen_id }} {
      gap: {{ block.settings.desktop_stats_gap }}px;
      margin-top: {{ block.settings.desktop_stats_margin_top }}px;
      padding-top: {{ block.settings.desktop_stats_padding_top }}px;
      flex-wrap: nowrap;
    }

    .vd-stat-num-{{ ai_gen_id }} {
      font-size: {{ block.settings.desktop_stat_number_size }}px;
    }

    .vd-stat-lbl-{{ ai_gen_id }} {
      font-size: {{ block.settings.desktop_stat_label_size }}px;
    }
  }
{% endstyle %}

<botanical-hero-{{ ai_gen_id }} class="vd-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="vd-hero-inner-{{ ai_gen_id }}">
    <div class="vd-grid-{{ ai_gen_id }}">
      <div class="vd-content-{{ ai_gen_id }}">
        {% if block.settings.eyebrow_text != blank %}
          <div class="vd-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</div>
        {% endif %}

        {% if block.settings.headline != blank %}
          <h1 class="vd-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
        {% endif %}

        {% if block.settings.subtext != blank %}
          <div class="vd-sub-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
        {% endif %}

        <div class="vd-cta-row-{{ ai_gen_id }}">
          {% if block.settings.primary_button_label != blank %}
            <a href="{{ block.settings.primary_button_link }}" class="vd-btn-primary-{{ ai_gen_id }}">
              {{ block.settings.primary_button_label }}
            </a>
          {% endif %}

          {% if block.settings.secondary_button_label != blank %}
            <a href="{{ block.settings.secondary_button_link }}" class="vd-btn-ghost-{{ ai_gen_id }}">
              {{ block.settings.secondary_button_label }}
            </a>
          {% endif %}
        </div>

        {% if block.settings.show_stats %}
          <div class="vd-stats-{{ ai_gen_id }}">
            {% if block.settings.stat_1_number != blank %}
              <div>
                <div class="vd-stat-num-{{ ai_gen_id }}">{{ block.settings.stat_1_number }}</div>
                <div class="vd-stat-lbl-{{ ai_gen_id }}">{{ block.settings.stat_1_label }}</div>
              </div>
            {% endif %}

            {% if block.settings.stat_2_number != blank %}
              <div>
                <div class="vd-stat-num-{{ ai_gen_id }}">{{ block.settings.stat_2_number }}</div>
                <div class="vd-stat-lbl-{{ ai_gen_id }}">{{ block.settings.stat_2_label }}</div>
              </div>
            {% endif %}

            {% if block.settings.stat_3_number != blank %}
              <div>
                <div class="vd-stat-num-{{ ai_gen_id }}">{{ block.settings.stat_3_number }}</div>
                <div class="vd-stat-lbl-{{ ai_gen_id }}">{{ block.settings.stat_3_label }}</div>
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <div class="vd-img-wrap-{{ ai_gen_id }}">
        <div class="vd-arch-{{ ai_gen_id }}">
          {% if block.settings.hero_image %}
            <img
              src="{{ block.settings.hero_image | image_url: width: 1024 }}"
              alt="{{ block.settings.hero_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.hero_image.width }}"
              height="{{ block.settings.hero_image.height }}"
            >
          {% else %}
            <div class="vd-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if block.settings.show_quote and block.settings.quote_text != blank %}
            <div class="vd-quote-{{ ai_gen_id }}">
              <p>{{ block.settings.quote_text }}</p>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</botanical-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class BotanicalHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('botanical-hero-{{ ai_gen_id }}', BotanicalHero{{ ai_gen_id }});
  })();
</script>

