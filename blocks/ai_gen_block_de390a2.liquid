
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-navbar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.nav_bg_color }};
    font-family: 'Source Sans 3', system-ui, sans-serif;
  }

  .ai-navbar-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.nav_padding_top_mobile }}px {{ block.settings.nav_padding_horizontal_mobile }}px {{ block.settings.nav_padding_bottom_mobile }}px;
  }

  .ai-navbar-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: {{ block.settings.nav_inner_padding_top_mobile }}px 0 {{ block.settings.nav_inner_padding_bottom_mobile }}px;
    gap: {{ block.settings.nav_gap_mobile }}px;
  }

  .ai-navbar-logo-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .ai-navbar-logo-image-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width_mobile }}px;
    height: auto;
    display: block;
  }

  .ai-navbar-logo-text-{{ ai_gen_id }} {
    font-family: 'Playfair Display', serif;
    font-size: {{ block.settings.logo_font_size_mobile }}px;
    font-weight: {{ block.settings.logo_font_weight }};
    color: {{ block.settings.logo_color }};
    letter-spacing: {{ block.settings.logo_letter_spacing }};
    text-transform: {{ block.settings.logo_text_transform }};
    line-height: 1.2;
  }

  .ai-navbar-actions-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }

  .ai-navbar-cart-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: {{ block.settings.cta_bg_color }};
    width: 32px;
    height: 32px;
    transition: color 0.3s ease;
  }

  .ai-navbar-cart-{{ ai_gen_id }}:hover {
    color: {{ block.settings.cta_hover_bg_color }};
  }

  .ai-navbar-cart-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }

  .ai-navbar-cart-bubble-{{ ai_gen_id }} {
    position: absolute;
    top: -2px;
    right: -2px;
    background-color: {{ block.settings.cta_hover_bg_color }};
    color: {{ block.settings.cta_hover_text_color }};
    font-size: 9px;
    font-weight: 700;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    border: 1.5px solid {{ block.settings.nav_bg_color }};
  }

  .ai-navbar-logo-text-{{ ai_gen_id }} em {
    font-style: {{ block.settings.logo_em_style }};
    color: {{ block.settings.logo_em_color }};
    font-weight: {{ block.settings.logo_em_font_weight }};
  }

  .ai-navbar-links-{{ ai_gen_id }} {
    display: none;
    gap: {{ block.settings.links_gap_mobile }}px;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-navbar-links-{{ ai_gen_id }} li {
    margin: 0;
    padding: 0;
  }

  .ai-navbar-links-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_font_size_mobile }}px;
    font-weight: {{ block.settings.link_font_weight }};
    letter-spacing: {{ block.settings.link_letter_spacing }};
    text-transform: {{ block.settings.link_text_transform }};
    transition: color 0.3s ease;
    display: block;
    padding: {{ block.settings.link_padding_vertical_mobile }}px {{ block.settings.link_padding_horizontal_mobile }}px;
  }

  .ai-navbar-links-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-navbar-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.cta_icon_gap_mobile }}px;
    padding: {{ block.settings.cta_padding_vertical_mobile }}px {{ block.settings.cta_padding_horizontal_mobile }}px;
    border-radius: {{ block.settings.cta_border_radius_mobile }}px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    font-size: {{ block.settings.cta_font_size_mobile }}px;
    font-weight: {{ block.settings.cta_font_weight }};
    letter-spacing: {{ block.settings.cta_letter_spacing }};
    text-transform: {{ block.settings.cta_text_transform }};
    text-decoration: none;
    border: {{ block.settings.cta_border_width }}px {{ block.settings.cta_border_style }} {{ block.settings.cta_border_color }};
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  .ai-navbar-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
    color: {{ block.settings.cta_hover_text_color }};
    border-color: {{ block.settings.cta_hover_border_color }};
  }

  @media (min-width: {{ block.settings.desktop_breakpoint }}px) {
    .ai-navbar-inner-{{ ai_gen_id }} {
      padding: {{ block.settings.nav_padding_top }}px {{ block.settings.nav_padding_horizontal }}px {{ block.settings.nav_padding_bottom }}px;
    }

    .ai-navbar-container-{{ ai_gen_id }} {
      padding: {{ block.settings.nav_inner_padding_top }}px 0 {{ block.settings.nav_inner_padding_bottom }}px;
      gap: {{ block.settings.nav_gap }}px;
    }

    .ai-navbar-links-{{ ai_gen_id }} {
      display: flex;
      gap: {{ block.settings.links_gap }}px;
    }

    .ai-navbar-links-{{ ai_gen_id }} a {
      font-size: {{ block.settings.link_font_size }}px;
      padding: {{ block.settings.link_padding_vertical }}px {{ block.settings.link_padding_horizontal }}px;
    }

    .ai-navbar-logo-image-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width }}px;
    }

    .ai-navbar-logo-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.logo_font_size }}px;
    }

    .ai-navbar-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_font_size }}px;
      padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
      gap: {{ block.settings.cta_icon_gap }}px;
      border-radius: {{ block.settings.cta_border_radius }}px;
    }
  }
{% endstyle %}

<nav-bar-{{ ai_gen_id }} class="ai-navbar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-navbar-inner-{{ ai_gen_id }}">
    <div class="ai-navbar-container-{{ ai_gen_id }}">
      <a href="{{ block.settings.logo_link | default: '/' }}" class="ai-navbar-logo-{{ ai_gen_id }}">
        {% if block.settings.logo_image %}
          <img
            src="{{ block.settings.logo_image | image_url: width: 400 }}"
            alt="{{ block.settings.logo_image.alt | default: shop.name | escape }}"
            class="ai-navbar-logo-image-{{ ai_gen_id }}"
            width="{{ block.settings.logo_width }}"
            height="auto"
            loading="lazy"
          >
        {% else %}
          <span class="ai-navbar-logo-text-{{ ai_gen_id }}">
            {{ block.settings.logo_text }}
          </span>
        {% endif %}
      </a>

      {% if block.settings.show_nav_links %}
        <ul class="ai-navbar-links-{{ ai_gen_id }}">
          {% if block.settings.link_1_text != blank %}
            <li>
              <a href="{{ block.settings.link_1_url | default: '#' }}">
                {{ block.settings.link_1_text }}
              </a>
            </li>
          {% endif %}
          {% if block.settings.link_2_text != blank %}
            <li>
              <a href="{{ block.settings.link_2_url | default: '#' }}">
                {{ block.settings.link_2_text }}
              </a>
            </li>
          {% endif %}
          {% if block.settings.link_3_text != blank %}
            <li>
              <a href="{{ block.settings.link_3_url | default: '#' }}">
                {{ block.settings.link_3_text }}
              </a>
            </li>
          {% endif %}
          {% if block.settings.link_4_text != blank %}
            <li>
              <a href="{{ block.settings.link_4_url | default: '#' }}">
                {{ block.settings.link_4_text }}
              </a>
            </li>
          {% endif %}
          {% if block.settings.link_5_text != blank %}
            <li>
              <a href="{{ block.settings.link_5_url | default: '#' }}">
                {{ block.settings.link_5_text }}
              </a>
            </li>
          {% endif %}
        </ul>
      {% endif %}

      <div class="ai-navbar-actions-{{ ai_gen_id }}">
        {% if block.settings.show_cta %}
          <a href="{{ block.settings.cta_url | default: '#' }}" class="ai-navbar-cta-{{ ai_gen_id }}">
            {{ block.settings.cta_text }}
          </a>
        {% endif %}

        <a href="{{ routes.cart_url }}" class="ai-navbar-cart-{{ ai_gen_id }}" data-cart-sidebar aria-label="{{ 'general.cart.cart' | t }}">
          {% render 'icon-cart' %}
          <span class="ai-navbar-cart-bubble-{{ ai_gen_id }}" data-cart-count>{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </div>
</nav-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class NavBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const navbar = this;
        let lastScrollTop = 0;

        if ({{ block.settings.enable_sticky | json }}) {
          window.addEventListener('scroll', function() {
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            
            if (scrollTop > lastScrollTop && scrollTop > 100) {
              navbar.style.transform = 'translateY(-100%)';
              navbar.style.transition = 'transform 0.3s ease';
            } else {
              navbar.style.transform = 'translateY(0)';
            }
            
            lastScrollTop = scrollTop;
          });

          navbar.style.position = 'sticky';
          navbar.style.top = '0';
          navbar.style.zIndex = '1000';
        }
      }
    }

    customElements.define('nav-bar-{{ ai_gen_id }}', NavBar{{ ai_gen_id }});
  })();
</script>

