
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-newsletter-{{ ai_gen_id }} {
    display: block;
    background: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding_top_desktop }}px {{ block.settings.padding_horizontal_desktop }}px {{ block.settings.padding_bottom_desktop }}px;
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .ai-newsletter-{{ ai_gen_id }}::before,
  .ai-newsletter-{{ ai_gen_id }}::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    opacity: {{ block.settings.decoration_opacity }};
    pointer-events: none;
  }

  .ai-newsletter-{{ ai_gen_id }}::before {
    width: {{ block.settings.decoration_1_size }}px;
    height: {{ block.settings.decoration_1_size }}px;
    background: radial-gradient(circle, {{ block.settings.decoration_1_color }} 0%, transparent 70%);
    top: {{ block.settings.decoration_1_top }}px;
    left: {{ block.settings.decoration_1_left }}px;
  }

  .ai-newsletter-{{ ai_gen_id }}::after {
    width: {{ block.settings.decoration_2_size }}px;
    height: {{ block.settings.decoration_2_size }}px;
    background: radial-gradient(circle, {{ block.settings.decoration_2_color }} 0%, transparent 70%);
    bottom: {{ block.settings.decoration_2_bottom }}px;
    right: {{ block.settings.decoration_2_right }}px;
  }

  .ai-newsletter-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_align }};
    position: relative;
    z-index: 1;
  }

  .ai-newsletter-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_font_size_desktop }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }};
    text-transform: {{ block.settings.eyebrow_text_transform }};
    color: {{ block.settings.eyebrow_color }};
    opacity: {{ block.settings.eyebrow_opacity }};
    margin-bottom: {{ block.settings.eyebrow_margin_bottom }}px;
    font-weight: {{ block.settings.eyebrow_font_weight }};
  }

  .ai-newsletter-title-{{ ai_gen_id }} {
    font-weight: {{ block.settings.title_font_weight }};
    font-size: {{ block.settings.title_font_size_desktop }}px;
    line-height: {{ block.settings.title_line_height }};
    letter-spacing: {{ block.settings.title_letter_spacing }};
    margin: {{ block.settings.title_margin_top }}px 0 {{ block.settings.title_margin_bottom }}px;
    color: {{ block.settings.title_color }};
  }

  .ai-newsletter-title-{{ ai_gen_id }} em {
    font-style: {{ block.settings.title_em_style }};
    color: {{ block.settings.title_em_color }};
    font-weight: {{ block.settings.title_em_font_weight }};
  }

  .ai-newsletter-sub-{{ ai_gen_id }} {
    color: {{ block.settings.subtitle_color }};
    line-height: {{ block.settings.subtitle_line_height }};
    margin: 0 auto {{ block.settings.subtitle_margin_bottom }}px;
    max-width: {{ block.settings.subtitle_max_width }}px;
    font-size: {{ block.settings.subtitle_font_size_desktop }}px;
    font-weight: {{ block.settings.subtitle_font_weight }};
  }

  .ai-newsletter-form-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.form_gap }}px;
    max-width: {{ block.settings.form_max_width }}px;
    margin: 0 auto;
    background: {{ block.settings.form_background }};
    border-radius: {{ block.settings.form_border_radius }}px;
    padding: {{ block.settings.form_padding }}px;
    box-shadow: 0 {{ block.settings.form_shadow_y }}px {{ block.settings.form_shadow_blur }}px {{ block.settings.form_shadow_spread }}px {{ block.settings.form_shadow_color }};
    flex-wrap: wrap;
    border: {{ block.settings.form_border_width }}px {{ block.settings.form_border_style }} {{ block.settings.form_border_color }};
  }

  .ai-newsletter-input-{{ ai_gen_id }} {
    flex: 1;
    min-width: {{ block.settings.input_min_width }}px;
    border: {{ block.settings.input_border_width }}px {{ block.settings.input_border_style }} {{ block.settings.input_border_color }};
    background: {{ block.settings.input_background }};
    padding: {{ block.settings.input_padding_vertical }}px {{ block.settings.input_padding_horizontal }}px;
    font-size: {{ block.settings.input_font_size_desktop }}px;
    color: {{ block.settings.input_text_color }};
    outline: none;
    border-radius: {{ block.settings.input_border_radius }}px;
    font-weight: {{ block.settings.input_font_weight }};
  }

  .ai-newsletter-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_placeholder_color }};
  }

  .ai-newsletter-input-{{ ai_gen_id }}:focus {
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-newsletter-btn-{{ ai_gen_id }} {
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px {{ block.settings.button_border_style }} {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-size: {{ block.settings.button_font_size_desktop }}px;
    letter-spacing: {{ block.settings.button_letter_spacing }};
    text-transform: {{ block.settings.button_text_transform }};
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: {{ block.settings.button_font_weight }};
    min-width: {{ block.settings.button_min_width }}px;
  }

  .ai-newsletter-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-newsletter-fine-{{ ai_gen_id }} {
    font-size: {{ block.settings.fine_print_font_size_desktop }}px;
    color: {{ block.settings.fine_print_color }};
    margin: {{ block.settings.fine_print_margin_top }}px 0 0;
    opacity: {{ block.settings.fine_print_opacity }};
    font-weight: {{ block.settings.fine_print_font_weight }};
  }

  .ai-newsletter-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: {{ block.settings.success_margin_top }}px;
    font-size: {{ block.settings.success_font_size }}px;
    font-weight: {{ block.settings.success_font_weight }};
  }

  .ai-newsletter-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: {{ block.settings.error_margin_top }}px;
    font-size: {{ block.settings.error_font_size }}px;
    font-weight: {{ block.settings.error_font_weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-newsletter-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-newsletter-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size_mobile }}px;
    }

    .ai-newsletter-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-newsletter-sub-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_font_size_mobile }}px;
    }

    .ai-newsletter-input-{{ ai_gen_id }} {
      font-size: {{ block.settings.input_font_size_mobile }}px;
      min-width: 100%;
    }

    .ai-newsletter-btn-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
      width: {{ block.settings.button_width_mobile }}%;
      min-width: auto;
    }

    .ai-newsletter-fine-{{ ai_gen_id }} {
      font-size: {{ block.settings.fine_print_font_size_mobile }}px;
    }

    {% if block.settings.mobile_stack_button %}
      .ai-newsletter-form-{{ ai_gen_id }} {
        flex-direction: column;
      }

      .ai-newsletter-btn-{{ ai_gen_id }} {
        width: {{ block.settings.button_width_mobile }}%;
        margin: 0 auto;
      }
    {% endif %}
  }
{% endstyle %}

<newsletter-form-{{ ai_gen_id }} class="ai-newsletter-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {%- form 'contact' -%}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <div class="ai-newsletter-inner-{{ ai_gen_id }}">
      {% if block.settings.eyebrow_text != blank %}
        <div class="ai-newsletter-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</div>
      {% endif %}

      {% if block.settings.title != blank %}
        <h2 class="ai-newsletter-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <div class="ai-newsletter-sub-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
      {% endif %}

      <div class="ai-newsletter-form-{{ ai_gen_id }}">
        <input
          type="email"
          name="contact[email]"
          class="ai-newsletter-input-{{ ai_gen_id }}"
          value="{{ form.email }}"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="ai-newsletter-error-{{ ai_gen_id }}"
          {% endif %}
          {% if form.posted_successfully? %}
            aria-describedby="ai-newsletter-success-{{ ai_gen_id }}"
          {% endif %}
          placeholder="{{ block.settings.input_placeholder }}"
          required
        >
        <button type="submit" class="ai-newsletter-btn-{{ ai_gen_id }}">
          {% if form.posted_successfully? %}
            {{ block.settings.button_success_text }}
          {% else %}
            {{ block.settings.button_text }}
          {% endif %}
        </button>
      </div>

      {%- if form.errors -%}
        <div id="ai-newsletter-error-{{ ai_gen_id }}" class="ai-newsletter-error-{{ ai_gen_id }}">
          <span>{{ form.errors.messages.email }}</span>
        </div>
      {%- endif -%}

      {%- if form.posted_successfully? -%}
        <div id="ai-newsletter-success-{{ ai_gen_id }}" class="ai-newsletter-success-{{ ai_gen_id }}">
          <span>{{ block.settings.success_message }}</span>
        </div>
      {%- endif -%}

      {% if block.settings.fine_print != blank %}
        <p class="ai-newsletter-fine-{{ ai_gen_id }}">{{ block.settings.fine_print }}</p>
      {% endif %}
    </div>
  {%- endform -%}
</newsletter-form-{{ ai_gen_id }}>

<script>
  (function() {
    class NewsletterForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form) {
          this.handleFormSubmit(form);
        }
      }

      handleFormSubmit(form) {
        form.addEventListener('submit', function(e) {
          const button = form.querySelector('.ai-newsletter-btn-{{ ai_gen_id }}');
          if (button) {
            button.disabled = true;
          }
        });
      }
    }

    customElements.define('newsletter-form-{{ ai_gen_id }}', NewsletterForm{{ ai_gen_id }});
  })();
</script>

