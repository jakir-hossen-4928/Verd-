
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-section-{{ ai_gen_id }} {
    display: block;
    background: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    width: 100%;
  }

  .ai-benefits-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-benefits-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_margin_bottom_mobile }}px;
  }

  .ai-benefits-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_font_size_mobile }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }};
    text-transform: {{ block.settings.eyebrow_text_transform }};
    color: {{ block.settings.eyebrow_color }};
    margin: 0 0 {{ block.settings.eyebrow_margin_bottom_mobile }}px;
    font-weight: {{ block.settings.eyebrow_font_weight }};
    line-height: {{ block.settings.eyebrow_line_height }};
  }

  .ai-benefits-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size_mobile }}px;
    line-height: {{ block.settings.title_line_height }};
    letter-spacing: {{ block.settings.title_letter_spacing }};
    margin: 0;
    color: {{ block.settings.title_color }};
    font-weight: {{ block.settings.title_font_weight }};
    font-style: {{ block.settings.title_font_style }};
  }

  .ai-benefits-title-{{ ai_gen_id }} em {
    font-style: {{ block.settings.title_em_font_style }};
    color: {{ block.settings.title_em_color }};
    font-weight: {{ block.settings.title_em_font_weight }};
  }

  .ai-benefits-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: {{ block.settings.grid_gap_mobile }}px;
  }

  .ai-benefits-item-{{ ai_gen_id }} {
    text-align: {{ block.settings.item_alignment }};
    padding: {{ block.settings.item_padding }}px;
  }

  .ai-benefits-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_mobile }}px;
    height: {{ block.settings.icon_size_mobile }}px;
    margin: 0 auto {{ block.settings.icon_margin_bottom_mobile }}px;
    border-radius: {{ block.settings.icon_border_radius }}px;
    background: {{ block.settings.icon_background }};
    border: {{ block.settings.icon_border_width }}px {{ block.settings.icon_border_style }} {{ block.settings.icon_border_color }};
    display: grid;
    place-items: center;
    color: {{ block.settings.icon_color }};
    overflow: hidden;
  }

  .ai-benefits-icon-{{ ai_gen_id }} svg {
    width: {{ block.settings.svg_size_mobile }}px;
    height: {{ block.settings.svg_size_mobile }}px;
    stroke-width: {{ block.settings.svg_stroke_width }};
  }

  .ai-benefits-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-benefits-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_font_size_mobile }}px;
    font-weight: {{ block.settings.name_font_weight }};
    margin: 0 0 {{ block.settings.name_margin_bottom_mobile }}px;
    color: {{ block.settings.name_color }};
    line-height: {{ block.settings.name_line_height }};
    letter-spacing: {{ block.settings.name_letter_spacing }};
    font-style: {{ block.settings.name_font_style }};
  }

  .ai-benefits-desc-{{ ai_gen_id }} {
    font-size: {{ block.settings.desc_font_size_mobile }}px;
    color: {{ block.settings.desc_color }};
    line-height: {{ block.settings.desc_line_height }};
    margin: 0;
    max-width: {{ block.settings.desc_max_width }}px;
    margin-inline: auto;
    font-weight: {{ block.settings.desc_font_weight }};
    letter-spacing: {{ block.settings.desc_letter_spacing }};
  }

  @media (min-width: 700px) {
    .ai-benefits-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap_tablet }}px;
    }

    .ai-benefits-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_tablet }}px;
      height: {{ block.settings.icon_size_tablet }}px;
      margin-bottom: {{ block.settings.icon_margin_bottom_tablet }}px;
    }

    .ai-benefits-icon-{{ ai_gen_id }} svg {
      width: {{ block.settings.svg_size_tablet }}px;
      height: {{ block.settings.svg_size_tablet }}px;
    }

    .ai-benefits-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.name_font_size_tablet }}px;
      margin-bottom: {{ block.settings.name_margin_bottom_tablet }}px;
    }

    .ai-benefits-desc-{{ ai_gen_id }} {
      font-size: {{ block.settings.desc_font_size_tablet }}px;
    }

    .ai-benefits-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size_tablet }}px;
      margin-bottom: {{ block.settings.eyebrow_margin_bottom_tablet }}px;
    }

    .ai-benefits-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_tablet }}px;
    }

    .ai-benefits-header-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.header_margin_bottom_tablet }}px;
    }

    .ai-benefits-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_tablet }}px {{ block.settings.padding_horizontal_tablet }}px {{ block.settings.padding_bottom_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    .ai-benefits-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.grid_gap_desktop }}px;
    }

    .ai-benefits-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_desktop }}px;
      height: {{ block.settings.icon_size_desktop }}px;
      margin-bottom: {{ block.settings.icon_margin_bottom_desktop }}px;
    }

    .ai-benefits-icon-{{ ai_gen_id }} svg {
      width: {{ block.settings.svg_size_desktop }}px;
      height: {{ block.settings.svg_size_desktop }}px;
    }

    .ai-benefits-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.name_font_size_desktop }}px;
      margin-bottom: {{ block.settings.name_margin_bottom_desktop }}px;
    }

    .ai-benefits-desc-{{ ai_gen_id }} {
      font-size: {{ block.settings.desc_font_size_desktop }}px;
    }

    .ai-benefits-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size_desktop }}px;
      margin-bottom: {{ block.settings.eyebrow_margin_bottom_desktop }}px;
    }

    .ai-benefits-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_desktop }}px;
    }

    .ai-benefits-header-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.header_margin_bottom_desktop }}px;
    }

    .ai-benefits-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_desktop }}px {{ block.settings.padding_horizontal_desktop }}px {{ block.settings.padding_bottom_desktop }}px;
    }
  }
{% endstyle %}

<benefits-section-{{ ai_gen_id }} class="ai-benefits-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-benefits-inner-{{ ai_gen_id }}">
    <header class="ai-benefits-header-{{ ai_gen_id }}">
      {% if block.settings.eyebrow_text != blank %}
        <div class="ai-benefits-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</div>
      {% endif %}
      {% if block.settings.title_text != blank %}
        <h2 class="ai-benefits-title-{{ ai_gen_id }}">{{ block.settings.title_text }}</h2>
      {% endif %}
    </header>
    <div class="ai-benefits-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign benefit_enabled_key = 'benefit_' | append: i | append: '_enabled'
          assign benefit_title_key = 'benefit_' | append: i | append: '_title'
          assign benefit_desc_key = 'benefit_' | append: i | append: '_desc'
          assign benefit_icon_type_key = 'benefit_' | append: i | append: '_icon_type'
          assign benefit_icon_key = 'benefit_' | append: i | append: '_icon'
          assign benefit_image_key = 'benefit_' | append: i | append: '_image'

          assign benefit_enabled = block.settings[benefit_enabled_key]
          assign benefit_title = block.settings[benefit_title_key]
          assign benefit_desc = block.settings[benefit_desc_key]
          assign benefit_icon_type = block.settings[benefit_icon_type_key]
          assign benefit_icon = block.settings[benefit_icon_key]
          assign benefit_image = block.settings[benefit_image_key]
        %}

        {% if benefit_enabled %}
          <div class="ai-benefits-item-{{ ai_gen_id }}">
            <div class="ai-benefits-icon-{{ ai_gen_id }}">
              {% if benefit_icon_type == 'image' and benefit_image %}
                <img
                  src="{{ benefit_image | image_url: width: 200 }}"
                  alt="{{ benefit_title | escape }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% elsif benefit_icon_type == 'svg' %}
                {% if benefit_icon == 'sparkles' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
                  </svg>
                {% elsif benefit_icon == 'droplet' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2C8 6 6 9 6 13a6 6 0 0 0 12 0c0-4-2-7-6-11Z"/>
                  </svg>
                {% elsif benefit_icon == 'heart' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 4c-1 2-1 4 0 6"/>
                    <path d="M15 4c1 2 1 4 0 6"/>
                    <circle cx="12" cy="16" r="5"/>
                  </svg>
                {% elsif benefit_icon == 'globe' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0ZM12 3v18M3 12h18"/>
                  </svg>
                {% elsif benefit_icon == 'leaf' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
                    <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
                  </svg>
                {% elsif benefit_icon == 'shield' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                {% elsif benefit_icon == 'check' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                {% elsif benefit_icon == 'star' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                {% elsif benefit_icon == 'award' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="8" r="6"/>
                    <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
                  </svg>
                {% elsif benefit_icon == 'box' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                    <line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                {% elsif benefit_icon == 'truck' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="3" width="15" height="13"/>
                    <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                    <circle cx="5.5" cy="18.5" r="2.5"/>
                    <circle cx="18.5" cy="18.5" r="2.5"/>
                  </svg>
                {% endif %}
              {% endif %}
            </div>
            {% if benefit_title != blank %}
              <h3 class="ai-benefits-name-{{ ai_gen_id }}">{{ benefit_title }}</h3>
            {% endif %}
            {% if benefit_desc != blank %}
              <p class="ai-benefits-desc-{{ ai_gen_id }}">{{ benefit_desc }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</benefits-section-{{ ai_gen_id }}>

<script>
  (function() {
    class BenefitsSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('benefits-section-{{ ai_gen_id }}', BenefitsSection{{ ai_gen_id }});
  })();
</script>

