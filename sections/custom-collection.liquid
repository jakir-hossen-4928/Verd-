      "id": "text_color_mobile",
      "label": "Text Color",
      "default": "#2D3A31"
    },
    {
      "type": "color",
      "id": "accent_color_mobile",
      "label": "Accent Color",
      "default": "#8C9A84"
    },
    {
      "type": "color",
      "id": "desc_color_mobile",
      "label": "Description Color",
      "default": "#4a5a50"
    },
    {
      "type": "header",
      "content": "Colors — Desktop"
    },
    {
      "type": "color",
      "id": "bg_color_desktop",
      "label": "Background Color",
      "default": "#F9F8F4"
    },
    {
      "type": "color",
      "id": "text_color_desktop",
      "label": "Text Color",
      "default": "#2D3A31"
    },
    {
      "type": "color",
