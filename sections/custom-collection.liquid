{% comment %}
  Collections Grid Section
  Fully customizable with mobile/desktop breakpoint controls
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} {
    --coll-bg-mobile: {{ section.settings.bg_color_mobile }};
    --coll-text-mobile: {{ section.settings.text_color_mobile }};
    --coll-accent-mobile: {{ section.settings.accent_color_mobile }};
    --coll-desc-mobile: {{ section.settings.desc_color_mobile }};
    
    --coll-bg-desktop: {{ section.settings.bg_color_desktop }};
    --coll-text-desktop: {{ section.settings.text_color_desktop }};
    --coll-accent-desktop: {{ section.settings.accent_color_desktop }};
    --coll-desc-desktop: {{ section.settings.desc_color_desktop }};
    
    --coll-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --coll-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --coll-padding-left-mobile: {{ section.settings.padding_left_mobile }}px;
    --coll-padding-right-mobile: {{ section.settings.padding_right_mobile }}px;
    
    --coll-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --coll-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --coll-padding-left-desktop: {{ section.settings.padding_left_desktop }}px;
    --coll-padding-right-desktop: {{ section.settings.padding_right_desktop }}px;
    
    --coll-max-width: {{ section.settings.max_width }}px;
    --coll-gap-mobile: {{ section.settings.gap_mobile }}px;
    --coll-gap-desktop: {{ section.settings.gap_desktop }}px;
    
    --coll-eyebrow-size-mobile: {{ section.settings.eyebrow_size_mobile }}px;
    --coll-eyebrow-size-desktop: {{ section.settings.eyebrow_size_desktop }}px;
    --coll-eyebrow-spacing: {{ section.settings.eyebrow_spacing }}em;
    
    --coll-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --coll-title-size-desktop: {{ section.settings.title_size_desktop }}px;
    --coll-title-weight: {{ section.settings.title_weight }};
    
    --coll-desc-size-mobile: {{ section.settings.desc_size_mobile }}px;
    --coll-desc-size-desktop: {{ section.settings.desc_size_desktop }}px;
    --coll-desc-max-width: {{ section.settings.desc_max_width }}px;
    
    --coll-card-bg: {{ section.settings.card_bg_color }};
    --coll-card-radius: {{ section.settings.card_border_radius }}px;
    --coll-card-shadow: {{ section.settings.card_shadow }};
    --coll-card-shadow-hover: {{ section.settings.card_shadow_hover }};
    --coll-card-translate: {{ section.settings.card_hover_translate }}px;
    
    --coll-img-radius-top: {{ section.settings.img_border_radius_top }}px;
    --coll-img-radius-bottom: {{ section.settings.img_border_radius_bottom }}px;
    --coll-img-aspect-ratio: {{ section.settings.img_aspect_ratio }};
    --coll-img-bg: {{ section.settings.img_bg_color }};
    
    --coll-name-size-mobile: {{ section.settings.name_size_mobile }}px;
    --coll-name-size-desktop: {{ section.settings.name_size_desktop }}px;
    --coll-name-weight: {{ section.settings.name_weight }};
    
    --coll-meta-size-mobile: {{ section.settings.meta_size_mobile }}px;
    --coll-meta-size-desktop: {{ section.settings.meta_size_desktop }}px;
    --coll-meta-spacing: {{ section.settings.meta_spacing }}em;
    
    --coll-arrow-size: {{ section.settings.arrow_size }}px;
    --coll-arrow-border: {{ section.settings.arrow_border_width }}px solid {{ section.settings.arrow_border_color }};
    --coll-arrow-bg: {{ section.settings.arrow_bg_color }};
    --coll-arrow-hover-bg: {{ section.settings.arrow_hover_bg_color }};
    --coll-arrow-hover-border-color: {{ section.settings.arrow_hover_border_color }};
    
    --coll-grid-cols-mobile: {{ section.settings.grid_cols_mobile }};
    --coll-grid-cols-desktop: {{ section.settings.grid_cols_desktop }};
    --coll-offset-enabled: {{ section.settings.enable_offset }};
    --coll-offset-amount: {{ section.settings.offset_amount }}px;
    
    --coll-body-padding: {{ section.settings.body_padding }}px;
    --coll-body-gap: {{ section.settings.body_gap }}px;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      --coll-bg: var(--coll-bg-desktop);
      --coll-text: var(--coll-text-desktop);
      --coll-accent: var(--coll-accent-desktop);
      --coll-desc: var(--coll-desc-desktop);
      --coll-padding-top: var(--coll-padding-top-desktop);
      --coll-padding-bottom: var(--coll-padding-bottom-desktop);
      --coll-padding-left: var(--coll-padding-left-desktop);
      --coll-padding-right: var(--coll-padding-right-desktop);
      --coll-gap: var(--coll-gap-desktop);
      --coll-eyebrow-size: var(--coll-eyebrow-size-desktop);
      --coll-title-size: var(--coll-title-size-desktop);
      --coll-desc-size: var(--coll-desc-size-desktop);
      --coll-name-size: var(--coll-name-size-desktop);
      --coll-meta-size: var(--coll-meta-size-desktop);
      --coll-grid-cols: var(--coll-grid-cols-desktop);
    }
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --coll-bg: var(--coll-bg-mobile);
      --coll-text: var(--coll-text-mobile);
      --coll-accent: var(--coll-accent-mobile);
      --coll-desc: var(--coll-desc-mobile);
      --coll-padding-top: var(--coll-padding-top-mobile);
      --coll-padding-bottom: var(--coll-padding-bottom-mobile);
      --coll-padding-left: var(--coll-padding-left-mobile);
      --coll-padding-right: var(--coll-padding-right-mobile);
      --coll-gap: var(--coll-gap-mobile);
      --coll-eyebrow-size: var(--coll-eyebrow-size-mobile);
      --coll-title-size: var(--coll-title-size-mobile);
      --coll-desc-size: var(--coll-desc-size-mobile);
      --coll-name-size: var(--coll-name-size-mobile);
      --coll-meta-size: var(--coll-meta-size-mobile);
      --coll-grid-cols: var(--coll-grid-cols-mobile);
    }
  }

  .collections-section-{{ section.id }} {
    background: var(--coll-bg);
    color: var(--coll-text);
    padding: var(--coll-padding-top) var(--coll-padding-right) var(--coll-padding-bottom) var(--coll-padding-left);
  }

  .collections-inner-{{ section.id }} {
    max-width: var(--coll-max-width);
    margin: 0 auto;
  }

  .collections-head-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.head_gap_mobile }}px;
    margin-bottom: {{ section.settings.head_margin_bottom }}px;
  }

  @media (min-width: 1024px) {
    .collections-head-{{ section.id }} {
      grid-template-columns: {{ section.settings.head_grid_ratio }};
      gap: {{ section.settings.head_gap_desktop }}px;
    }
  }

  .collections-eyebrow-{{ section.id }} {
    font-size: var(--coll-eyebrow-size);
    letter-spacing: var(--coll-eyebrow-spacing);
    text-transform: {{ section.settings.eyebrow_transform }};
    color: var(--coll-accent);
    font-weight: {{ section.settings.eyebrow_weight }};
  }

  .collections-title-{{ section.id }} {
    font-family: {{ section.settings.title_font.family }};
    font-weight: var(--coll-title-weight);
    font-size: var(--coll-title-size);
    line-height: {{ section.settings.title_line_height }};
    letter-spacing: {{ section.settings.title_letter_spacing }}em;
    margin: {{ section.settings.title_margin_top }}px 0 0;
    color: var(--coll-text);
  }

  .collections-title-{{ section.id }} em {
    font-style: italic;
    color: var(--coll-accent);
    font-weight: {{ section.settings.title_italic_weight }};
  }

  .collections-desc-{{ section.id }} {
    color: var(--coll-desc);
    max-width: var(--coll-desc-max-width);
    line-height: {{ section.settings.desc_line_height }};
    margin: 0;
    font-size: var(--coll-desc-size);
  }

  .collections-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(var(--coll-grid-cols), 1fr);
    gap: var(--coll-gap);
  }

  .collection-card-{{ section.id }} {
    position: relative;
    display: block;
    background: var(--coll-card-bg);
    border-radius: var(--coll-card-radius);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform {{ section.settings.hover_duration }}s {{ section.settings.hover_easing }}, box-shadow {{ section.settings.hover_duration }}s {{ section.settings.hover_easing }};
    box-shadow: var(--coll-card-shadow);
  }

  .collection-card-{{ section.id }}:hover {
    transform: translateY(calc(-1 * var(--coll-card-translate)));
    box-shadow: var(--coll-card-shadow-hover);
  }

  {% if section.settings.enable_offset and section.settings.enable_offset_desktop %}
    @media (min-width: 1024px) {
      .collections-grid-{{ section.id }} > :nth-child(even) {
        transform: translateY(var(--coll-offset-amount));
      }
    }
  {% endif %}

  .card-img-wrapper-{{ section.id }} {
    position: relative;
    aspect-ratio: var(--coll-img-aspect-ratio);
    overflow: hidden;
    border-top-left-radius: var(--coll-img-radius-top);
    border-top-right-radius: var(--coll-img-radius-top);
    border-bottom-left-radius: var(--coll-img-radius-bottom);
    border-bottom-right-radius: var(--coll-img-radius-bottom);
    margin: {{ section.settings.img_margin }}px;
    background: var(--coll-img-bg);
  }

  .card-img-wrapper-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.img_object_fit }};
    display: block;
    transition: transform {{ section.settings.img_hover_duration }}s {{ section.settings.img_hover_easing }};
  }

  .collection-card-{{ section.id }}:hover .card-img-wrapper-{{ section.id }} img {
    transform: scale({{ section.settings.img_hover_scale }});
  }

  .card-body-{{ section.id }} {
    padding: var(--coll-body-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--coll-body-gap);
  }

  .card-name-{{ section.id }} {
    font-family: {{ section.settings.title_font.family }}, {{ section.settings.title_font.fallback_families }};
    font-size: var(--coll-name-size);
    font-weight: var(--coll-name-weight);
    margin: 0;
    color: var(--coll-text);
  }

  .card-meta-{{ section.id }} {
    font-size: var(--coll-meta-size);
    letter-spacing: var(--coll-meta-spacing);
    text-transform: {{ section.settings.meta_transform }};
    color: var(--coll-accent);
    margin-top: {{ section.settings.meta_margin_top }}px;
  }

  .card-arrow-{{ section.id }} {
    width: var(--coll-arrow-size);
    height: var(--coll-arrow-size);
    border-radius: 999px;
    border: var(--coll-arrow-border);
    background: var(--coll-arrow-bg);
    display: grid;
    place-items: center;
    transition: all {{ section.settings.hover_duration }}s {{ section.settings.hover_easing }};
    color: currentColor;
  }

  .collection-card-{{ section.id }}:hover .card-arrow-{{ section.id }} {
    background: var(--coll-arrow-hover-bg);
    border-color: var(--coll-arrow-hover-border-color);
    color: {{ section.settings.arrow_hover_text_color }};
  }

  .card-arrow-{{ section.id }} svg {
    width: {{ section.settings.arrow_icon_size }}px;
    height: {{ section.settings.arrow_icon_size }}px;
  }
{% endstyle %}

<div class="collections-section-{{ section.id }}">
  <div class="collections-inner-{{ section.id }}">
    <header class="collections-head-{{ section.id }}">
      <div>
        {% if section.settings.show_eyebrow %}
          <div class="collections-eyebrow-{{ section.id }}">{{ section.settings.eyebrow_text }}</div>
        {% endif %}
        <h2 class="collections-title-{{ section.id }}">
          {{ section.settings.title_html }}
        </h2>
      </div>
      {% if section.settings.show_description %}
        <p class="collections-desc-{{ section.id }}">
          {{ section.settings.description }}
        </p>
      {% endif %}
    </header>

    <div class="collections-grid-{{ section.id }}">
      {% for block in section.blocks %}
        {% assign collection = block.settings.collection %}
        <a 
          href="{{ block.settings.link_url | default: collection.url }}" 
          class="collection-card-{{ section.id }}"
          {{ block.shopify_attributes }}
        >
          <div class="card-img-wrapper-{{ section.id }}">
            {% if block.settings.custom_image %}
              {{ block.settings.custom_image | image_url: width: 800 | image_tag: 
                loading: 'lazy', 
                widths: '400,600,800,1000', 
                sizes: '(min-width: 1024px) 300px, (min-width: 768px) 45vw, 100vw',
                alt: block.settings.image_alt | default: block.settings.title
              }}
            {% else %}
              {% assign placeholder_index = forloop.index0 | modulo: 4 %}
              {% case placeholder_index %}
                {% when 0 %}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% when 1 %}
                  {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
                {% when 2 %}
                  {{ 'collection-3' | placeholder_svg_tag: 'placeholder-svg' }}
                {% when 3 %}
                  {{ 'collection-4' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endcase %}
            {% endif %}
          </div>
          <div class="card-body-{{ section.id }}">
            <div>
              <h3 class="card-name-{{ section.id }}">{{ block.settings.title | default: collection.title }}</h3>
              {% if section.settings.show_product_count and collection %}
                <div class="card-meta-{{ section.id }}">{{ collection.all_products_count | default: block.settings.custom_count }} {{ section.settings.product_count_label }}</div>
              {% elsif block.settings.custom_count_text != blank %}
                <div class="card-meta-{{ section.id }}">{{ block.settings.custom_count_text }}</div>
              {% endif %}
            </div>
            {% if section.settings.show_arrow %}
              <span class="card-arrow-{{ section.id }}" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ section.settings.arrow_stroke_width }}">
                  <path d="M5 12h14M13 5l7 7-7 7"/>
                </svg>
              </span>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>


{% schema %}
{
  "name": "Collections Grid",
  "settings": [
    {
      "type": "header",
      "content": "Colors — Mobile"
    },
    {
      "type": "color",
      "id": "bg_color_mobile",
      "label": "Background Color",
      "default": "#F9F8F4"
